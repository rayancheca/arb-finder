# ─────────────────────────────────────────────────────────────────────
# arb-finder environment variables
# Copy to apps/web/.env for local dev, set in Vercel/Railway for prod.
# NEVER commit the real .env file — it's gitignored.
# ─────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────
# Local dev: absolute SQLite path. Prisma resolves file:// URLs
# differently between CLI and runtime, so always use absolute paths.
DATABASE_URL="file:/absolute/path/to/arb-finder/db/dev.db"

# Production (Neon Postgres): pooled connection string + direct URL.
# Get these from the Neon console after creating a database.
#   DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.aws.neon.tech/neondb?sslmode=require
#   DIRECT_URL=postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require

NODE_ENV="development"

# ── Worker ───────────────────────────────────────────────────────────
# Poll cadence in seconds. Default 300 (5 min).
ARB_POLL_INTERVAL_SECONDS=300

# Circuit breaker: how many consecutive failures before a book is
# shelved, and how long (seconds) the first backoff lasts.
ARB_MAX_FAILURES=3
ARB_COOLDOWN=900

# Log level: DEBUG|INFO|WARNING|ERROR
ARB_LOG_LEVEL=INFO

# ── Per-book secrets ─────────────────────────────────────────────────
# BetMGM rotates the public API access id. Get yours from DevTools:
#   1. Open sports.ny.betmgm.com in a logged-in browser
#   2. DevTools → Network → reload → filter by "fixtures"
#   3. Copy the `x-bwin-accessid` query param
BETMGM_ACCESS_ID=

# ── Notifications (Phase G) ─────────────────────────────────────────
# Slack / Discord webhook — worker fires when netReturnPct > 5%
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
