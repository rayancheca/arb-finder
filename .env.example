# arb-finder environment
#
# DATABASE_URL must be an ABSOLUTE path for SQLite. Prisma resolves file://
# URLs differently between the CLI (relative to the schema file) and the
# runtime client (relative to CWD), so always use absolute paths in dev.
#
# Example (replace with your own absolute path):
DATABASE_URL="file:/absolute/path/to/arb-finder/db/dev.db"

NODE_ENV="development"
